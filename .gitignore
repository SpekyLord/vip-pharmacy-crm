# Claude Code permission allowlist (accumulates session commands — can capture test creds, paths)
.claude/settings.json

# Playwright MCP session debris (regenerated each run)
.playwright-mcp/

# Git worktrees for parallel-phase isolation (Rule 0e)
.worktrees/

# Smoke-test screenshots — block ALL pngs at repo root.
# Real assets live in frontend/public/, frontend/src/assets/, etc. and are unaffected.
# Local screenshots stay on disk for inspection but never get staged.
/*.png

# Migration / merge audit logs — accumulated during apply runs.
# Precedent: A.5.2 bulk-merge CSVs + G7.A.0 migration JSON shipped accidentally.
/reports/

# Playwright MCP YAML snapshots that occasionally land at repo root.
# Real .playwright-mcp/ dir already covered above; these are leakage.
/grn-*.yml
/grn-*.yaml
/cc-*.yml
# Phase P1.2 Slice 7-ext Round 2B + Slice 8/9 smoke artifacts.
/capture-*.yml
/capture-*.yaml

# Third-party Agent Skills (coreyhaines31/marketingskills, etc.).
# Restore on a fresh clone with: npx skills experimental_install
# skills-lock.json IS committed so the install is reproducible.
.agents/
.claude/skills/*
# But keep our own project-local skills under version control.
!.claude/skills/pharma-marketing-compliance-ph/
