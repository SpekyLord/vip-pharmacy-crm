# ===========================================
# VIP Pharmacy CRM - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# -------------------------------------------
# Server Configuration
# -------------------------------------------
# Application environment: development, production, test
NODE_ENV=development

# Port the server will listen on
PORT=5000

# -------------------------------------------
# Database Configuration
# -------------------------------------------
# MongoDB connection string
# For local: mongodb://localhost:27017/vip-pharmacy-crm
# For Atlas: mongodb+srv://<username>:<password>@cluster.xxxxx.mongodb.net/vip-pharmacy-crm
MONGO_URI=your_mongodb_atlas_connection_string

# -------------------------------------------
# JWT Authentication
# -------------------------------------------
# Secret key for signing access tokens (use a long random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_long_random_secret_key_here

# Access token expiration time (e.g., 15m, 1h, 1d)
JWT_EXPIRE=15m

# Secret key for signing refresh tokens (different from JWT_SECRET)
JWT_REFRESH_SECRET=your_refresh_token_secret

# Refresh token expiration time
JWT_REFRESH_EXPIRE=7d

# -------------------------------------------
# AWS S3 Configuration (Image Upload)
# -------------------------------------------
# Get these values from AWS IAM Console
# Create an IAM user with S3 access permissions
# https://console.aws.amazon.com/iam/

# AWS Access Key ID
AWS_ACCESS_KEY_ID=your_aws_access_key_id

# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AWS Region (e.g., us-east-1, ap-southeast-1)
AWS_REGION=us-east-1

# S3 Bucket Name for storing images
# Create a bucket in S3 console: https://s3.console.aws.amazon.com/
S3_BUCKET_NAME=vip-pharmacy-crm-uploads

# -------------------------------------------
# CORS Configuration
# -------------------------------------------
# Frontend application URL (for CORS whitelist in development)
# Vite default: http://localhost:5173
# Create React App default: http://localhost:3000
CLIENT_URL=http://localhost:5173

# CORS Origins (REQUIRED in production)
# Comma-separated list of allowed origins
# Example: https://your-domain.com,https://www.your-domain.com
# CORS_ORIGINS=https://your-production-domain.com

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
# Time window for rate limiting in milliseconds (15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000

# Maximum number of requests per window per IP
RATE_LIMIT_MAX_REQUESTS=100

# -------------------------------------------
# Login Rate Limiting
# -------------------------------------------
# Maximum login attempts before lockout
LOGIN_MAX_ATTEMPTS=5

# Lockout duration in minutes
LOGIN_LOCKOUT_DURATION=15
