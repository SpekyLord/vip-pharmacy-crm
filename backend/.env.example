# ===========================================
# VIP CRM - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# -------------------------------------------
# Server Configuration
# -------------------------------------------
NODE_ENV=development
PORT=5000

# -------------------------------------------
# Database Configuration
# -------------------------------------------
# CRM database connection string
# Production:  mongodb+srv://<user>:<pass>@cluster0.e9wenoo.mongodb.net/vip-pharmacy-crm?retryWrites=true&w=majority&appName=Cluster0
# Development: mongodb+srv://<user>:<pass>@cluster0.e9wenoo.mongodb.net/vip-pharmacy-crm-dev?retryWrites=true&w=majority&appName=Cluster0
MONGO_URI=your_mongodb_atlas_connection_string

# Website products database name (read-only cross-DB product catalog)
# Production:  vip-pharmacy
# Development: vip-pharmacy-dev
WEBSITE_DB_NAME=vip-pharmacy

# -------------------------------------------
# JWT Authentication
# -------------------------------------------
# SECURITY: Must be at least 64 characters each!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET=replace_with_64_char_secret
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=replace_with_different_64_char_secret
JWT_REFRESH_EXPIRE=7d

# -------------------------------------------
# AWS S3 Configuration (Image Upload)
# -------------------------------------------
# IAM user credentials from AWS Console
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=vip-pharmacy-crm-prod

# -------------------------------------------
# Google Cloud Vision (ERP OCR)
# -------------------------------------------
# For local dev:
#   1) Install gcloud CLI
#   2) Run: gcloud auth application-default login
#   3) Set quota project: gcloud auth application-default set-quota-project <project-id>
#
# For deployed backend: use a service account JSON key file or GOOGLE_VISION_KEY_JSON

GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id

# Path to service account JSON key file (local/dev)
# Example: C:\keys\vip-vision-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# Alternative: paste full service account JSON as escaped single-line string (for hosted envs)
GOOGLE_VISION_KEY_JSON=

# Default Vision feature for scanned docs (e.g. DOCUMENT_TEXT_DETECTION)
GOOGLE_VISION_DEFAULT_FEATURE=DOCUMENT_TEXT_DETECTION

# -------------------------------------------
# CORS Configuration
# -------------------------------------------
CLIENT_URL=http://localhost:5173

# REQUIRED in production — server will not start without this
# Comma-separated: https://your-domain.com,https://www.your-domain.com
# Leave empty for development
CORS_ORIGINS=

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_GENERAL_MAX=500
RATE_LIMIT_AUTH_MAX=50
RATE_LIMIT_USER_MAX=300

# -------------------------------------------
# Login Rate Limiting
# -------------------------------------------
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=15

# -------------------------------------------
# Excel Import Hardening
# -------------------------------------------
IMPORT_MAX_FILE_SIZE_MB=5
IMPORT_MAX_WORKBOOK_SHEETS=30
IMPORT_MAX_WORKSHEET_ROWS=2000

# -------------------------------------------
# Resend (Email Notifications)
# -------------------------------------------
# Sign up at https://resend.com → Domains → Add domain → follow DNS TXT record setup
# Then: API Keys → Create key
# Domain to verify: viosintegrated.net
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=yourpartner@viosintegrated.net

# true = log emails to console only (keep true in dev, false in production!)
SES_SANDBOX_MODE=true

# Used in email links (password reset, etc.)
FRONTEND_URL=http://localhost:5173

# -------------------------------------------
# Facebook Messenger
# -------------------------------------------
# 1. Go to developers.facebook.com → Create App (type: Business)
# 2. Add Messenger product → Link "VIP Pharmacy" Facebook Page
# 3. Generate a Page Access Token → paste below
# 4. Choose any secret string for FB_VERIFY_TOKEN (you will paste it in Meta dashboard too)
# 5. Webhook URL to register in Meta: https://yourserver.com/api/webhooks/messenger
# 6. Subscribe to: messages, messaging_deliveries, messaging_reads
FB_PAGE_ACCESS_TOKEN=
FB_VERIFY_TOKEN=

# -------------------------------------------
# Viber Business Bot
# -------------------------------------------
# 1. Apply at partners.viber.com → Service Messages (free tier)
# 2. Use contact # 09177760079 on the application form
# 3. After approval you receive a bot token → paste below
# 4. Register webhook ONCE after deployment (Viber requires a curl call, not a dashboard setting):
#
#   curl -X POST https://chatapi.viber.com/pa/set_webhook \
#     -H "X-Viber-Auth-Token: <VIBER_BOT_TOKEN>" \
#     -H "Content-Type: application/json" \
#     -d '{"url":"https://yourserver.com/api/webhooks/viber","event_types":["delivered","seen","message"]}'
#
#   Expected response: {"status":0,"status_message":"ok"}
VIBER_BOT_TOKEN=

# -------------------------------------------
# WhatsApp Cloud API (future)
# -------------------------------------------
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# -------------------------------------------
# Runtime Controls
# -------------------------------------------
# Keep false for API process; set true only for dedicated worker process
ENABLE_SCHEDULER=false

# Show dependency details in /api/health/ready (true in dev, false in prod)
HEALTH_EXPOSE_DETAILS=true

# -------------------------------------------
# Anthropic (Claude AI — ERP features)
# -------------------------------------------
# Get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# -------------------------------------------
# Alerting (Optional)
# -------------------------------------------
# Webhook URL for scheduler/operational failure alerts
ALERT_WEBHOOK_URL=
